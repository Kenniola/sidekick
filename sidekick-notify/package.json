{
  "name": "sidekick-notify",
  "displayName": "Sidekick Notify",
  "description": "Toast notifications for Sidekick meeting findings",
  "version": "0.3.0",
  "publisher": "koladimeji",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sidekick-notify.showStatus",
        "title": "Sidekick: Show Status"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "@vscode/vsce": "^3.0.0"
  }
}
